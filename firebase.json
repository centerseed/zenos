{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "dashboard/out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "/installers/**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0" }]
      }
    ],
    "rewrites": [
      {
        "source": "/marketing",
        "destination": "/marketing.html"
      },
      {
        "source": "/clients/deals/**",
        "destination": "/clients/deals/_.html"
      },
      {
        "source": "/clients/companies/**",
        "destination": "/clients/companies/_.html"
      }
    ]
  }
}
