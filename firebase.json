{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "dashboard/out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      {
        "source": "/clients/deals/**",
        "destination": "/clients/deals/_.html"
      },
      {
        "source": "/clients/companies/**",
        "destination": "/clients/companies/_.html"
      }
    ]
  }
}
