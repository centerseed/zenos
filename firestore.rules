rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwnPartner(partnerDoc) {
      return isAuthenticated() && request.auth.token.email == partnerDoc.data.email;
    }

    // ── Partners: self-read only, writes via Admin SDK only ──
    match /partners/{partnerId} {
      // Restrict partner reads to self only. Admin/team listing must use Admin API.
      allow read: if isOwnPartner(resource);
      allow write: if false;
    }

    // ── Ontology collections: authenticated read, writes via Admin SDK ──

    match /entities/{entityId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /relationships/{relId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // collectionGroup query for relationships (used by getAllRelationships)
    match /{path=**}/relationships/{relId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /documents/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /protocols/{protocolId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /blindspots/{blindspotId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Action Layer: tasks ──
    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow write: if false;  // All writes via Admin SDK (MCP server)
    }

    // ── Action Layer: partner-scoped tasks ──
    match /partners/{partnerId}/tasks/{taskId} {
      allow read: if isAuthenticated()
        && request.auth.token.email
           == get(/databases/$(database)/documents/partners/$(partnerId)).data.email;
      allow write: if false;
    }
  }
}
