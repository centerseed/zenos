rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Partners: authenticated users can read all (for People Matrix),
    //    writes via Admin SDK only ──
    match /partners/{partnerId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Ontology collections: authenticated read, writes via Admin SDK ──

    match /entities/{entityId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /relationships/{relId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    match /documents/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /protocols/{protocolId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /blindspots/{blindspotId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Action Layer: tasks ──
    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow write: if false;  // All writes via Admin SDK (MCP server)
    }
  }
}
